rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isNotChanging(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Admins ───────────────────────────────────────────────────────────────

    match /admins/{uid} {
      // Admins can read their own record; bootstrap script uses Admin SDK
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false; // Admin SDK only
    }

    // ─── Products (public catalog) ───────────────────────────────────────────

    match /products/{productId} {
      // Anyone (including unauthenticated) can read active products
      allow read: if resource.data.isActive == true || isAdmin();
      // Admin web app can manage products
      allow write: if isAdmin();
    }

    // ─── Users ───────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Users can only read their own document; admins can read all
      allow read: if isOwner(uid) || isAdmin();

      // Client can only update safe profile fields
      // stripeCustomerId is CF-only (blocked here)
      allow update: if isOwner(uid)
        && isNotChanging('stripeCustomerId')
        && isNotChanging('createdAt')
        // Only allow updating display name, default shipping, lastSignInAt
        && request.resource.data.keys().hasOnly([
             'email', 'displayName', 'defaultShipping',
             'lastSignInAt', 'stripeCustomerId', 'createdAt', 'fcmTokens'
           ]);

      // Created by Cloud Function (createUserRecord) only
      allow create: if false;
      allow delete: if false;

      // ─── Eye Photos subcollection ─────────────────────────────────────────
      match /eyePhotos/{photoId} {
        // Users can read their own eye photos; admins can read any
        allow read: if isOwner(uid) || isAdmin();

        // Client can create (upload after user confirmation)
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasAll(['originalStoragePath', 'croppedStoragePath', 'capturedAt', 'isActive', 'metadata'])
          && request.resource.data.isActive == true;

        // Updates and deletes are Cloud Function only
        // (deleteEyePhoto CF handles cleanup)
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─── User Events (analytics) ─────────────────────────────────────────────

    match /userEvents/{eventId} {
      // Users can only write their own events
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'type', 'timestamp', 'sessionId']);
      allow read, update, delete: if isAdmin();
    }

    // ─── Orders ──────────────────────────────────────────────────────────────

    match /orders/{orderId} {
      // Users can only read their own orders; admins can read all
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid)
                  || isAdmin();

      // Client can create an order if:
      //   - userId matches their own UID
      //   - status is pending_payment
      //   - no payment field is set (payment written by CF only)
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending_payment'
        && !('payment' in request.resource.data)
        && request.resource.data.keys().hasAll([
             'userId', 'status',
             'productId', 'productSnapshot', 'shipping', 'pricing',
             'createdAt', 'updatedAt'
           ]);

      // Client can only update shipping address on pending orders;
      // admins can update status and fulfillment fields
      allow update: if (isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.status == 'pending_payment'
        && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['shipping', 'updatedAt'])
        // Never allow client to change payment or status
        && isNotChanging('payment')
        && isNotChanging('status')
        && isNotChanging('userId'))
        || isAdmin();

      allow delete: if false;
    }
  }
}
